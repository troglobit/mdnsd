.debhelper
autoreconf.after
autoreconf.before
debhelper-build-stamp
files
libmdnsd-dev/
libmdnsd-dev.*
libmdnsd/
libmdnsd2/
libmdnsd2.*
mdnsd.debhelper.log
mdnsd.substvars
mdnsd.postinst.debhelper
mdnsd.postrm.debhelper
mdnsd.prerm.debhelper
mdnsd/*
mquery.*
mquery/
tmp/

# .install files are source manifests, not build artifacts; keep them
# despite the broad <pkg>.* patterns above.
!*.install
